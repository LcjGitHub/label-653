# ============================================
# 后端环境变量配置示例
# ============================================
# 复制此文件为 .env 并根据实际情况修改

# 服务运行端口
PORT=3002

# Node.js 运行环境: development | production
NODE_ENV=development

# CORS 允许的源，多个用逗号分隔
# CORS_ORIGIN=http://localhost:3000,https://your-domain.com

# 数据库文件路径（相对或绝对路径）
# DB_PATH=./blog.db

# 请求体大小限制
# MAX_BODY_SIZE=10mb
