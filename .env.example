# ============================================
# 博客系统环境变量配置示例
# ============================================
# 复制此文件为 .env 并根据实际情况修改配置
# 注意: .env 文件已被 .gitignore 忽略，不要提交到仓库

# ---------- Docker 镜像配置 ----------
# CI/CD 自动部署时使用的镜像地址
# 如果使用 GitHub Container Registry，格式为: ghcr.io/用户名/仓库名-服务名:latest
BACKEND_IMAGE=ghcr.io/your-username/blog-backend:latest
FRONTEND_IMAGE=ghcr.io/your-username/blog-frontend:latest

# 本地开发时可以使用本地构建的镜像
# BACKEND_IMAGE=blog-backend:latest
# FRONTEND_IMAGE=blog-frontend:latest

# ---------- 后端服务配置 ----------
# 后端运行端口（容器内部端口，映射见 docker-compose.yml）
BACKEND_PORT=3002
NODE_ENV=production

# ---------- 部署服务器配置（GitHub Actions Secrets） ----------
# 以下配置需要在 GitHub 仓库的 Settings -> Secrets and variables -> Actions 中设置:
#
# SERVER_HOST          部署服务器的 IP 地址或域名，例如: 192.168.1.100
# SERVER_USERNAME      SSH 登录用户名，例如: root
# SERVER_PORT          SSH 端口号，默认: 22
# SSH_PRIVATE_KEY      SSH 私钥内容（使用 cat ~/.ssh/id_rsa 获取）
# DEPLOY_PATH          服务器上的部署路径，例如: /opt/blog-app
